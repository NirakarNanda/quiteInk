# Deployment Environment Template
# Duplicate this file to '.env' and populate with real values for production

# The port your server runs on (e.g. 5000, 8080)
PORT=5000

# Connection string for your MongoDB database
MONGO_URI=mongodb://localhost:27017/quietink_db

# Secret key used for signing JWTs. Must be long and random in production.
JWT_SECRET=your_super_secret_jwt_key_here

# Allowed frontend origin (e.g. https://your-frontend-domain.com for production)
CORS_ORIGIN=http://localhost:3000

# Environment mode ('development' or 'production')
NODE_ENV=development
